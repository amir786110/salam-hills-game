# کپی این فایل رو به نام .env بساز و مقادیر واقعی رو جایگزین کن
# در لیارا/Render، این متغیرها رو در بخش Environment Variables پنل تنظیم کن (نه در این فایل)

# آدرس اتصال به دیتابیس PostgreSQL
# در لیارا: از صفحه دیتابیستون، بخش "اتصال از بیرون" یا "Connection String" رو کپی کن
# در Render: از دیتابیس PostgreSQL که ساختی، "Internal Database URL" رو کپی کن
DATABASE_URL=postgresql://user:password@host:5432/dbname

# یک رشته تصادفی و امن برای امضای توکن‌های ورود کاربران
# می‌تونی با این دستور یکی بسازی: openssl rand -base64 32
JWT_SECRET=یک-رشته-تصادفی-و-طولانی-اینجا-بذار

# (اختیاری) کنترل صریح SSL دیتابیس — معمولاً نیازی به تنظیمش نیست
# مقدار "true" یا "false". اگر ست نشه، خودکار تشخیص داده می‌شه.
# DB_SSL=false
