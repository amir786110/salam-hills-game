# کپی این فایل رو به نام .env بساز و مقادیر واقعی رو جایگزین کن
# در Render، این متغیرها رو در بخش Environment Variables تنظیم کن (نه در این فایل)

# آدرس اتصال به دیتابیس PostgreSQL
# در Render: از دیتابیس PostgreSQL که ساختی، "Internal Database URL" رو کپی کن
DATABASE_URL=postgresql://user:password@host:5432/dbname

# یک رشته تصادفی و امن برای امضای توکن‌های ورود کاربران
# می‌تونی با این دستور یکی بسازی: openssl rand -base64 32
JWT_SECRET=یک-رشته-تصادفی-و-طولانی-اینجا-بذار
